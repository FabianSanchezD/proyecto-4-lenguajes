<h1 class="text-2xl font-bold mb-6">Editar <%= @team.name %></h1>
<%= render "form", team: @team %>

<%= button_to "Eliminar selección", @team, method: :delete,
      form: { data: { turbo_confirm: "¿Eliminar la selección #{@team.name}?" } },
      class: "mt-4 px-4 py-2 bg-red-700 text-white hover:bg-red-600" %>
