<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold"><%= @team.name %></h1>
    <p class="text-gray-600"><%= @team.group ? "Grupo #{@team.group.name}" : "Sin grupo asignado" %><%= ", Bombo #{@team.pot}" if @team.pot %></p>
  </div>
  <%= link_to "Editar", edit_team_path(@team), class: "px-4 py-2 border border-gray-400 hover:bg-gray-200" %>
</div>

<div class="grid grid-cols-4 gap-4 mb-8">
  <div class="bg-white border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold"><%= @team.points %></p><p class="text-xs text-gray-500">Puntos</p>
  </div>
  <div class="bg-white border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold"><%= @team.goals_for %></p><p class="text-xs text-gray-500">Goles a favor</p>
  </div>
  <div class="bg-white border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold"><%= @team.goals_against %></p><p class="text-xs text-gray-500">Goles en contra</p>
  </div>
  <div class="bg-white border border-gray-200 p-4 text-center">
    <p class="text-2xl font-bold"><%= @team.goal_difference %></p><p class="text-xs text-gray-500">Diferencia</p>
  </div>
</div>

<div class="bg-white border border-gray-200 p-5">
  <h2 class="text-lg font-bold mb-3">Partidos</h2>
  <% if @matches.any? %>
    <ul class="divide-y divide-gray-200">
      <% @matches.each do |m| %>
        <li class="py-2 flex justify-between text-sm">
          <span><%= m.stage_name %>: <%= m.label %></span>
          <span><%= m.played? ? "#{m.home_goals} - #{m.away_goals}" : "Pendiente" %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-500 text-sm">Sin partidos registrados.</p>
  <% end %>
</div>
