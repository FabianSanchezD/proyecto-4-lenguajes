<!DOCTYPE html>
<html lang="es">
  <head>
    <title>Mundial FIFA 2026</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 text-gray-900 min-h-screen">
    <nav class="bg-gray-900 text-gray-100 border-b-4 border-green-700">
      <div class="container mx-auto px-5 py-3 flex flex-wrap items-center gap-6">
        <%= link_to "Mundial 2026", root_path, class: "text-lg font-semibold" %>
        <div class="flex flex-wrap gap-4 text-sm">
          <%= link_to "Inicio", root_path, class: "hover:text-white text-gray-300" %>
          <%= link_to "Sorteo", draw_path, class: "hover:text-white text-gray-300" %>
          <%= link_to "Grupos", groups_path, class: "hover:text-white text-gray-300" %>
          <%= link_to "Selecciones", teams_path, class: "hover:text-white text-gray-300" %>
          <%= link_to "Partidos", matches_path, class: "hover:text-white text-gray-300" %>
          <%= link_to "Clasificados", qualification_path, class: "hover:text-white text-gray-300" %>
          <%= link_to "Eliminación", knockout_path, class: "hover:text-white text-gray-300" %>
        </div>
      </div>
    </nav>

    <main class="container mx-auto px-5 py-8">
      <% if notice %>
        <div class="mb-4 border-l-4 border-green-700 bg-green-50 text-green-900 px-4 py-3"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-4 border-l-4 border-red-600 bg-red-50 text-red-800 px-4 py-3"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
