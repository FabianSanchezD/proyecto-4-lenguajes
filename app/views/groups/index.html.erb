<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Grupos del torneo</h1>
  <%= link_to "Nuevo grupo", new_group_path, class: "px-4 py-2 bg-gray-900 text-white hover:bg-gray-700" %>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @groups.each do |group| %>
    <div class="bg-white border border-gray-200 p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-bold"><%= link_to "Grupo #{group.name}", group, class: "hover:text-green-800" %></h2>
        <span class="text-xs bg-gray-100 border border-gray-200 px-2 py-1"><%= group.teams.count %>/4 equipos</span>
      </div>
      <ul class="text-sm text-gray-700 space-y-1 mb-4">
        <% group.teams.each do |team| %>
          <li><%= team.name %></li>
        <% end %>
        <% if group.teams.empty? %>
          <li class="text-gray-400 italic">Sin selecciones</li>
        <% end %>
      </ul>
      <div class="flex gap-4 text-sm">
        <%= link_to "Ver tabla", group, class: "text-green-800 hover:underline" %>
        <%= link_to "Editar", edit_group_path(group), class: "text-gray-500 hover:underline" %>
      </div>
    </div>
  <% end %>
</div>
