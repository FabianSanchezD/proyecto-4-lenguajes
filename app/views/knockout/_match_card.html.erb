<div class="bg-white border border-gray-200 text-sm">
  <% [[match.home_team, match.home_goals, match.home_penalties],
      [match.away_team, match.away_goals, match.away_penalties]].each do |team, goals, pens| %>
    <div class="flex justify-between items-center px-3 py-1.5 <%= 'border-b border-gray-100' if team == match.home_team %>">
      <span class="truncate <%= 'text-gray-400 italic' unless team %>"><%= team&.name || 'Por definir' %></span>
      <span class="text-gray-600 tabular-nums">
        <% if match.played? %><%= goals %><% if pens %> (<%= pens %>)</span><% end %><% end %>
      </span>
    </div>
  <% end %>
  <div class="px-3 py-1 text-center border-t border-gray-100">
    <% if match.teams_defined? %>
      <%= link_to (match.played? ? "Editar" : "Registrar"), edit_match_path(match), class: "text-xs text-green-800 hover:underline" %>
    <% else %>
      <span class="text-xs text-gray-300">Por definir</span>
    <% end %>
  </div>
</div>
