<div class="flex items-center justify-between mb-6 flex-wrap gap-3">
  <h1 class="text-2xl font-bold">Sorteo de grupos</h1>
  <div class="flex gap-3">
    <%= link_to "Agregar selección", new_team_path, class: "px-4 py-2 border border-gray-400 hover:bg-gray-200 text-sm" %>
    <%= button_to "Sortear grupos", draw_path, method: :post,
          form: { data: { turbo_confirm: "Esto reorganizará los 12 grupos por bombos y borrará los resultados actuales. ¿Continuar?" } },
          class: "px-4 py-2 bg-gray-900 text-white hover:bg-gray-700 text-sm" %>
  </div>
</div>

<p class="text-gray-600 mb-6">
  El sorteo aleatorio respeta los 4 bombos (un equipo de cada bombo por grupo) y las sedes de los
  anfitriones (México en A, Canadá en B, Estados Unidos en D). También puedes asignar el grupo y el
  bombo de cada selección manualmente desde su edición.
</p>

<h2 class="text-lg font-bold mb-3">Bombos</h2>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
  <% [1, 2, 3, 4].each do |pot| %>
    <div class="bg-white border border-gray-200 p-4">
      <h3 class="font-bold mb-2">Bombo <%= pot %></h3>
      <ul class="text-sm space-y-1">
        <% (@pots[pot] || []).each do |team| %>
          <li class="flex justify-between">
            <%= link_to team.name, edit_team_path(team), class: "hover:text-green-800" %>
            <span class="text-gray-400"><%= team.group ? team.group.name : "" %></span>
          </li>
        <% end %>
        <% if (@pots[pot] || []).empty? %>
          <li class="text-gray-400 italic">Sin selecciones</li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>

<h2 class="text-lg font-bold mb-3">Grupos</h2>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
  <% @groups.each do |group| %>
    <div class="bg-white border border-gray-200 p-4">
      <h3 class="font-bold mb-2"><%= link_to "Grupo #{group.name}", group, class: "hover:text-green-800" %></h3>
      <ul class="text-sm space-y-1">
        <% group.teams.sort_by { |t| t.pot || 9 }.each do |team| %>
          <li class="flex justify-between">
            <span><%= team.name %></span>
            <span class="text-xs text-gray-400">B<%= team.pot || "?" %></span>
          </li>
        <% end %>
        <% if group.teams.empty? %>
          <li class="text-gray-400 italic">Vacío</li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
